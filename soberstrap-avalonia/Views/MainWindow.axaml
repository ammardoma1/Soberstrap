<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
        x:Class="soberstrap_avalonia.Views.MainWindow"
        Icon="/Assets/icon.png"
        Title="Soberstrap"
        Width="980"
        Height="620"
        MinWidth="820"
        MinHeight="520">

  <Grid ColumnDefinitions="240,*">
    <Border Classes="sidebar" Grid.Column="0">
      <StackPanel Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Image Source="/Assets/icon.png" Width="32" Height="32" />
          <StackPanel>
            <TextBlock Text="Soberstrap" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Launcher" FontSize="12" Classes="muted" />
          </StackPanel>
        </StackPanel>

        <ListBox Name="NavList" Classes="nav" SelectionChanged="NavList_OnSelectionChanged">
          <ListBoxItem Tag="Bloxstrap">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="■" Classes="nav-icon" />
              <TextBlock Text="Bloxstrap" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Bootstrapper">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="▣" Classes="nav-icon" />
              <TextBlock Text="Bootstrapper" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Integrations">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="+" Classes="nav-icon" />
              <TextBlock Text="Integrations" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Mods">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="⬢" Classes="nav-icon" />
              <TextBlock Text="Mods" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="FastFlags">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="⚑" Classes="nav-icon" />
              <TextBlock Text="FastFlags" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="FastFlagEditor">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="✎" Classes="nav-icon" />
              <TextBlock Text="FastFlag Editor" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Appearance">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="◐" Classes="nav-icon" />
              <TextBlock Text="Appearance" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Behaviour">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="⌁" Classes="nav-icon" />
              <TextBlock Text="Behaviour" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="Shortcuts">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="↗" Classes="nav-icon" />
              <TextBlock Text="Shortcuts" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Tag="About">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="i" Classes="nav-icon" />
              <TextBlock Text="About" />
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </StackPanel>
    </Border>

    <Border Classes="content" Grid.Column="1">
      <ScrollViewer>
        <Grid>
          <StackPanel Name="PageBloxstrap" IsVisible="False" Spacing="10">
            <TextBlock Text="Bloxstrap" Classes="h1" />
            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="10">
                <CheckBox Name="CheckUpdatesToggle" Content="Check for updates" />
                <CheckBox Name="EnableAnalyticsToggle" Content="Enable analytics" />
                <CheckBox Name="ConfirmLaunchesToggle" Content="Confirm before launching" />
              </StackPanel>
            </Border>

            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="Sober" FontWeight="Bold" />
                <TextBlock Text="Flatpak ID" Classes="muted" />
                <TextBox Name="SoberFlatpakIdBox" />
                <TextBlock Text="Config Path (optional)" Classes="muted" />
                <TextBox Name="SoberConfigPathBox" />
                <TextBlock Text="Launch Args (optional)" Classes="muted" />
                <TextBox Name="SoberLaunchArgsBox" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Name="PageBootstrapper" IsVisible="False" Spacing="10">
            <TextBlock Text="Bootstrapper" Classes="h1" />
            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="10">
                <CheckBox Name="UseFastFlagManagerToggle" Content="Use FastFlag Manager" />
                <CheckBox Name="BackgroundUpdatesToggle" Content="Enable background updates" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Name="PageIntegrations" IsVisible="False" Spacing="10">
            <TextBlock Text="Integrations" Classes="h1" />
            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="10">
                <CheckBox Name="EnableActivityTrackingToggle" Content="Enable activity tracking" />
                <CheckBox Name="UseDiscordRichPresenceToggle" Content="Use Discord Rich Presence" />
                <CheckBox Name="ShowServerDetailsToggle" Content="Show server details" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Name="PageMods" IsVisible="False" Spacing="10">
            <TextBlock Text="Mods" Classes="h1" />
            <TextBlock Text="Not implemented yet." Classes="muted" />
          </StackPanel>

          <StackPanel Name="PageFastFlags" IsVisible="False" Spacing="8">
            <TextBlock Text="FastFlags" Classes="h1" />
            <TextBlock Text="Select a Fast Flags JSON file and launch Roblox Sober." Classes="muted" />

            <Border Classes="card" Margin="0,16,0,0">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="FAST FLAGS FILE" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                  <TextBlock Name="FlagsStatus" Text="No Fast Flags selected." />
                </StackPanel>
                <Button Name="ChooseFlagsButton" Grid.Column="1" Content="Choose JSON" Click="ChooseFlags_OnClick" />
              </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
              <Button Name="LaunchButton" Classes="primary" Content="Launch Sober" Click="Launch_OnClick" />
              <TextBlock Name="LaunchStatus" Classes="muted" />
            </StackPanel>
          </StackPanel>

        <StackPanel Name="PageFastFlagEditor" IsVisible="False" Spacing="10">
          <TextBlock Text="FastFlag Editor" Classes="h1" />
          <TextBlock Text="Edit Fast Flags stored in the Sober config." Classes="muted" />

          <Border Classes="card" Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Name="LoadFlagsButton" Content="Load from Sober" Click="LoadFlags_OnClick" />
                <Button Name="SaveFlagsButton" Classes="primary" Content="Save to Sober" Click="SaveFlags_OnClick" />
                <TextBlock Name="FlagsEditorStatus" Classes="muted" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="2*,*" RowDefinitions="Auto" Margin="0,8,0,0">
            <Border Classes="card" Grid.Column="0">
              <StackPanel Spacing="8">
                <TextBlock Text="Flags" FontWeight="Bold" />
                <ListBox Name="FlagsList" SelectionChanged="FlagsList_OnSelectionChanged" />
              </StackPanel>
            </Border>

            <Border Classes="card" Grid.Column="1" Margin="12,0,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="Key" Classes="muted" />
                <TextBox Name="FlagKeyBox" />
                <TextBlock Text="Value (JSON)" Classes="muted" />
                <TextBox Name="FlagValueBox" AcceptsReturn="False" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Name="AddOrUpdateFlagButton" Content="Add / Update" Click="AddOrUpdateFlag_OnClick" />
                  <Button Name="RemoveFlagButton" Content="Remove" Click="RemoveFlag_OnClick" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>

          <StackPanel Name="PageAppearance" IsVisible="False" Spacing="10">
            <TextBlock Text="Appearance" Classes="h1" />
            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="Theme" Classes="muted" />
                <ComboBox Name="ThemeCombo">
                  <ComboBoxItem Content="Dark" />
                  <ComboBoxItem Content="Light" />
                  <ComboBoxItem Content="System" />
                </ComboBox>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Name="PageBehaviour" IsVisible="False" Spacing="10">
            <TextBlock Text="Behaviour" Classes="h1" />
            <TextBlock Text="Not implemented yet." Classes="muted" />
          </StackPanel>

          <StackPanel Name="PageShortcuts" IsVisible="False" Spacing="10">
            <TextBlock Text="Shortcuts" Classes="h1" />
            <Border Classes="card" Margin="0,8,0,0">
              <StackPanel Spacing="10">
                <Button Name="CreateDesktopEntryButton" Content="Create desktop entry" Click="CreateDesktopEntry_OnClick" />
                <Button Name="RemoveDesktopEntryButton" Content="Remove desktop entry" Click="RemoveDesktopEntry_OnClick" />
                <Button Name="OpenConfigFolderButton" Content="Open config folder" Click="OpenConfigFolder_OnClick" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Name="PageAbout" IsVisible="False" Spacing="8">
            <TextBlock Text="About" Classes="h1" />
            <TextBlock Text="Soberstrap is a Linux port inspired by Bloxstrap." Classes="muted" />
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
